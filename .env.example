# Greenfield Coffee — environment variables
# Copy this file to .env.local and fill in the values from your Supabase project dashboard.
# .env.local is git-ignored; never commit credentials.

# ---- Supabase ---------------------------------------------------------------
# Get all four from your project's dashboard:
#   Settings → API Keys (newer Supabase projects)
#   Settings → API      (older Supabase projects, same fields under different name)
#
# The env var NAMES below are stable. The VALUES are what changed — Supabase
# rolled out a new key model in 2026. By end of 2026 the legacy JWT-based keys
# will be deprecated in favour of:
#
#   publishable  (sb_publishable_xxx) — replaces the old anon key, safe in browser
#   secret       (sb_secret_xxx)      — replaces the old service_role key, server-only
#
# Both old and new values work in the env var names below; the code accepts
# either shape.

# Browser-safe — read by both server and client. Required.
NEXT_PUBLIC_SUPABASE_URL=

# Browser-safe publishable/anon key. Required.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret/service_role key. NEVER expose to the browser. Required.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (from Project Settings → Database → Connection string) --------
# Used by packages/db to run migrations and regenerate TypeScript types.
# Format: postgresql://postgres:***@db.[REF].supabase.co:5432/postgres
# Optional for apps/web; required only if you run `pnpm --filter @greenfield/db generate`.
SUPABASE_DB_URL=

# ---- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Greenfield Coffee"
NEXT_PUBLIC_APP_URL=http://localhost:3000