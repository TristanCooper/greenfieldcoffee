# Greenfield Coffee — environment variables
# Copy this file to .env.local and fill in the values from your Supabase project dashboard.
# .env.local is git-ignored; never commit credentials.

# ---- Supabase (from Project Settings -> API) ---------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Database (from Project Settings -> Database -> Connection string) ------
# Used by packages/db to run migrations and regenerate TypeScript types.
# Format: postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_DB_URL=

# ---- App --------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="Greenfield Coffee"
NEXT_PUBLIC_APP_URL=http://localhost:3000